{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testMatch": ["<rootDir>/src/**/__test__/**/*.e2e-spec.ts"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@src/(.*)$": "<rootDir>/src/$1"
  },
  "setupFiles": ["<rootDir>/src/common/config/jest-setup-env.ts"],
  "globalSetup": "<rootDir>/src/common/config/jest-e2e-global-setup.ts"
}
