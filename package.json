{
  "name": "gubernamentales-backend-template",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:debug:prod": "node --inspect=0.0.0.0:9229 dist/main",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./jest-e2e.json",
    "test:e2e:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config ./jest-e2e.json --runInBand",
    "add:pg": "npm i pg",
    "add:mysql": "npm i mysql2",
    "add:mariadb": "npm i mysql2",
    "add:mssql": "npm i mssql",
    "add:oracle": "npm i oracledb"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^10.1.0",
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^6.1.0",
    "@nestjs/common": "^11.0.20",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.20",
    "@nestjs/platform-fastify": "^11.0.20",
    "@nestjs/swagger": "^11.1.4",
    "@nestjs/typeorm": "^11.0.0",
    "@pormeldev/axis-common-lib": "2.1.0",
    "@pormeldev/axis-ddd-core": "2.0.1",
    "@pormeldev/axis-logpublisher-edenor": "2.0.1",
    "@pormeldev/axis-module-health": "2.1.3",
    "@pormeldev/axis-module-logging-edenor": "2.0.1",
    "@pormeldev/axis-module-users": "2.0.1",
    "@pormeldev/axis-nestjs-common": "3.2.0",
    "@pormeldev/axis-service-authorization": "2.0.0",
    "@pormeldev/axis-service-authorization-awsvp": "2.0.0",
    "@pormeldev/axis-service-cache": "2.1.0",
    "@pormeldev/axis-service-cache-redis": "2.1.0",
    "@pormeldev/axis-service-database": "2.0.1",
    "@pormeldev/axis-service-database-typeorm": "2.0.0",
    "@pormeldev/axis-service-logger": "3.0.1",
    "@pormeldev/axis-service-logger-pino": "3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.2.3",
    "fastify": "^5.8.5",
    "pg": "8.22.0",
    "qs": "6.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.27"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.6",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.14.0",
    "@types/qs": "^6.9.18",
    "@types/supertest": "^6.0.2",
    "jest": "^30.2.0",
    "prettier": "^3.5.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.3"
  },
  "jest": {
    "moduleNameMapper": {
      "^@src/(.*)$": "<rootDir>/$1"
    },
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "testPathIgnorePatterns": [
      "\\.e2e-spec\\.ts$"
    ],
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/shared/config/jest-setup-env.ts"
    ]
  }
}
