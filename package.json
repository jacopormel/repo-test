{
  "name": "gubernamentales-backend-template",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.22.0+sha512.bf049efe995b28f527fd2b41ae0474ce29186f7edcb3bf545087bd61fbbebb2bf75362d1307fda09c2d288e1e499787ac12d4fcb617a974718a6051f2eee741c",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "nest build",
    "format": "biome format --write .",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:docker:dev": "nodemon",
    "start:debug": "nest start --debug --watch",
    "start:debug:prod": "node --inspect=0.0.0.0:9229 dist/main",
    "start:prod": "node dist/main",
    "lint": "biome lint --write .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "test": "jest --config ./jest.config.ts --detectOpenHandles",
    "test:watch": "jest --config ./jest.config.ts --watch",
    "test:cov": "jest --config ./jest.config.ts --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config ./jest.config.ts --runInBand",
    "test:e2e": "jest --config ./jest-e2e.json --detectOpenHandles",
    "test:e2e:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config ./jest-e2e.json --runInBand",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "pnpm run typeorm -- migration:generate ./src/common/migration/%npm_config_name% -d ./src/common/config/data-source.ts",
    "migration:create": "pnpm run typeorm -- migration:create ./src/common/migration/%npm_config_name% -d ./src/common/config/data-source.ts",
    "migration:run": "pnpm run typeorm -- migration:run -d ./src/common/config/data-source.ts",
    "migration:revert": "pnpm run typeorm -- migration:revert -d ./src/common/config/data-source.ts",
    "seed:run": "ts-node -r tsconfig-paths/register src/common/seed/seed.command.ts",
    "docker:up": "docker compose up -d",
    "docker:up:build": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "docker:logs": "docker compose logs -f api",
    "docker:ps": "docker compose ps"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^10.1.0",
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^6.1.0",
    "@nestjs/common": "^11.1.2",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.2",
    "@nestjs/platform-fastify": "^11.1.28",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/typeorm": "^11.0.0",
    "@pormeldev/axis-common-lib": "2.1.0",
    "@pormeldev/axis-ddd-core": "2.0.1",
    "@pormeldev/axis-logpublisher-edenor": "2.0.1",
    "@pormeldev/axis-module-health": "2.1.3",
    "@pormeldev/axis-module-logging-edenor": "2.0.1",
    "@pormeldev/axis-module-users": "2.0.1",
    "@pormeldev/axis-nestjs-common": "3.2.0",
    "@pormeldev/axis-service-authorization": "2.0.0",
    "@pormeldev/axis-service-authorization-awsvp": "2.0.0",
    "@pormeldev/axis-service-cache": "2.1.0",
    "@pormeldev/axis-service-cache-redis": "2.1.0",
    "@pormeldev/axis-service-database": "2.0.1",
    "@pormeldev/axis-service-database-typeorm": "2.0.0",
    "@pormeldev/axis-service-logger": "3.0.1",
    "@pormeldev/axis-service-logger-pino": "3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.2.3",
    "fastify": "^5.8.5",
    "pg": "8.22.0",
    "qs": "6.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.27"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@nestjs/testing": "^11.1.6",
    "@swc/core": "^1.15.46",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.14.0",
    "@types/qs": "^6.9.18",
    "@types/supertest": "^6.0.2",
    "jest": "^30.2.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.9.3"
  }
}
