# Con pnpm, este archivo (por ser de proyecto/commiteado) no expande el token
# por seguridad. Configuralo en tu ~/.npmrc de usuario o con:
#   pnpm config set "//npm.pkg.github.com/:_authToken" "$GITHUB_PAT"
# Ver sección "Acceso a @pormeldev/*" en el README.
@pormeldev:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_PAT}
