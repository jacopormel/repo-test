# Puerto en que corre la aplicación
APP_PORT=3000
# Timezone en que corre la aplicación - Debe ser UTC
TZ=UTC
# Requerido para que AUTHORIZATION_PROVIDER=allow-all arranque (ver app.module.ts):
# solo permitido en development/test. Cualquier otro valor (o ausente) lo rechaza,
# incluyendo staging - ahí se espera probar roles/permisos contra AWS Verified Permissions real.
NODE_ENV=development

# --- Swagger metadata ---
APP_TITLE=Gubernamentales Backend
APP_DESCRIPTION=API REST gubernamental basada en Axis
APP_VERSION=0.0.1


# --- Health Module ---
# El http status code que debe retornar cuando algún servicio no está disponible
HEALTH_ERROR_STATUS_CODE=503
# El http status code que debe retornar cuando todos los servicios están disponibles
HEALTH_OK_STATUS_CODE=200
# El texto que debe retornar cuando todos los servicios están disponibles
HEALTH_RUNNING_TEXT=Running
# El texto que debe retornar cuando algún servicio no está disponible
HEALTH_RUNNING_WITH_ERRORS_TEXT=Running with errors
# El timezone en que debe expresar fecha y hora
HEALTH_TIMEZONE=UTC

# --- CORS ---
# Lista de orígenes permitidos separados por coma (sin espacios extra necesarios, se recortan solos)
CORS_ORIGINS=http://localhost:3000

# --- Seeds ---
# Si es true, corre los seeds de datos de ejemplo al arrancar la app (ver src/common/seed).
# Pensado para desarrollo local; dejar en false en ambientes reales.
# Rechazado al arrancar si NODE_ENV=production (ver app.module.ts).
RUN_SEEDS_ON_STARTUP=true

# --- Redis ---
# Host de redis al que se debe conectar
REDIS_HOST=localhost
# Puerto al que se debe conectar
REDIS_PORT=6379
# Contraseña de redis
REDIS_PASSWORD=
# Si se usa TLS para la conexión. Valores posibles: true o false.
REDIS_TLS=false
# El default de tiempo en segundos que se retienen los valores en cache
REDIS_TTL=600
# El tiemṕo en milisegundos que se espera antes de lanzar un timeout para operaciones con redis
REDIS_TIMEOUT_MS=6000
# El namespace lógico que usará esta aplicación para almacenar valores en redis. Este valor debe ser único por aplicación.
CACHE_NAMESPACE=gubernamentales-backend

# --- OAuth2 / OIDC ---
# Tenant ID de Entra ID
OAUTH2SERVER_TENANT_ID=your-tenant-id
# El host del server OAUTH2
OAUTH2SERVER_AUTHORITY_HOST=https://login.microsoftonline.com
# Timeout en milisegundos
OAUTH2SERVER_TIMEOUT_MS=3000


# --- Servicio de authorization ---
# allow-all (default) otorga siempre acceso, sin llamar a AWS - SOLO para desarrollo local.
# Rechazado al arrancar si NODE_ENV != development (ver app.module.ts) - incluye staging,
# no solo production, para que roles/permisos se prueben con AWS Verified Permissions real
# en cualquier ambiente que no sea desarrollo local.
# awsvp usa AWS Verified Permissions real, requiere AWVP_* abajo y credenciales de AWS.
AUTHORIZATION_PROVIDER=allow-all

# --- Servicio de authorization basado en AWS Verified Permissions---
# Solo requeridas si AUTHORIZATION_PROVIDER=awsvp (el default).
# Region de AWS en que está configurado el policy store de esta aplicación
AWVP_REGION=us-east-1
# Id de policy store de Verified Permissions que define las políticas de acceso de esta aplicación
AWVP_POLICY_STORE_ID=your-policy-store-id
# El namespace usado en el scheme de ese policy store
AWVP_NAMESPACE=gubernamentales


# --- Axis Logger ---
# El nivel de logging que se desea
AXIS_LOG_LEVEL=debug
# El timezone en que se debe expresar el timestamp de cada log
AXIS_LOG_TZ=UTC
# El nombre del campo que contiene el timestamp del log
AXIS_LOG_TS_NAME=time
# El nombre del campo que se usará como prefijo en cada log
AXIS_LOG_PREFIX_NAME=serviceName
# El valor que se usará como prefijo en cada log
AXIS_LOG_PREFIX_VALUE=gubernamentales-backend
# El nombre de la aplicación que se usará en cada log
AXIS_LOG_APP_NAME=Gubernamentales Backend
# Tipo de integración: ONLINE o BATCH
AXIS_LOG_INTEGRATION_TYPE=ONLINE
# Target de los logs: console en desarrollo local; en un ambiente real, el destino que corresponda (p.ej. splunk)
AXIS_LOG_TARGET=console
# Formato en que se emiten los logs: text o json
AXIS_LOG_FORMAT=text
# Si el formato es text, se puede poner true para que salgan con colores que faciliten la lectura en consola de los logs
AXIS_LOG_COLORS=true
# Si quiere logear todas las queries de TypeORM. Si se pone en true, emite logs, si pone false no emite logs y dependen los logs de los logpublishers.
TYPEORM_QUERY_LOGS=false


# --- Configuración de base de datos ---
# Motor único de este proyecto: PostgreSQL. DB_TYPE es requerido por el
# validador de Axis al arrancar; no cambiar de valor.
DB_TYPE=postgres

DB_MASTER_HOST=localhost                 # host de la instancia de Postgres
DB_MASTER_PORT=5432                      # puerto de Postgres
DB_MASTER_DATABASE=gubernamentales       # nombre de la base
DB_MASTER_USERNAME=gubernamentales       # usuario local
DB_MASTER_PASSWORD=gubernamentales_dev   # solo para desarrollo local; reemplazar en ambientes reales

# Número de réplicas de lectura (0 si no usas replicación)
DB_SLAVE_COUNT=0
DB_REPLICATION_ENABLED=false             # true para habilitar read/write split
# DB_REPLICATION_DEFAULT_MODE=master     # master|slave (por defecto, si no seteas, usa el default del driver)

# Configuración de esclavos (descomenta y ajusta si DB_SLAVE_COUNT > 0)
# DB_SLAVE1_HOST=localhost
# DB_SLAVE1_PORT=5432
# DB_SLAVE1_DATABASE=gubernamentales
# DB_SLAVE1_USERNAME=gubernamentales
# DB_SLAVE1_PASSWORD=YourStrongPassw0rd

# DB_SLAVE2_HOST=localhost
# DB_SLAVE2_PORT=5432
# DB_SLAVE2_DATABASE=gubernamentales
# DB_SLAVE2_USERNAME=gubernamentales
# DB_SLAVE2_PASSWORD=YourStrongPassw0rd

# --- Configuración específica de PostgreSQL ---
POSTGRES_SCHEMA=public                    # esquema por defecto
POSTGRES_SSL=false                        # habilitar SSL
POSTGRES_SSL_REJECT_UNAUTHORIZED=true     # validar certificado si SSL=true
POSTGRES_APP_NAME=gubernamentales-backend # application_name del cliente
POSTGRES_POOL_MAX=10                      # máximo conexiones pool
POSTGRES_POOL_IDLE_MS=30000               # idle antes de cierre (ms)
