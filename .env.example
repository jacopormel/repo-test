# Puerto en que corre la aplicación
APP_PORT=3000
# Timezone en que corre la aplicación - Debe ser UTC
TZ=UTC

# --- Swagger metadata ---
APP_TITLE=Plantilla de ejemplo Edenor
APP_DESCRIPTION=API REST que sirve como plantilla de desarrollo de Backend de Edenor
APP_VERSION=1.0.0


# --- Health Module ---
# El http status code que debe retornar cuando algún servicio no está disponible
HEALTH_ERROR_STATUS_CODE=505
# El http status code que debe retornar cuando todos los servicios están disponibles
HEALTH_OK_STATUS_CODE=200
# El texto que debe retornar cuando todos los servicios están disponibles
HEALTH_RUNNING_TEXT=Running
# El texto que debe retornar cuando algún servicio no está disponible
HEALTH_RUNNING_WITH_ERRORS_TEXT=Running with errors
# El timezone en que debe expresar fecha y hora
HEALTH_TIMEZONE=America/Argentina/Buenos_Aires

# --- Redis ---
# Host de redis al que se debe conectar
REDIS_HOST=localhost
# Puerto al que se debe conectar
REDIS_PORT=6379
# Contraseña de redis
REDIS_PASSWORD=
# Si se usa TLS para la conexión. Valores posibles: true o false.
REDIS_TLS=false
# El default de tiempo en segundos que se retienen los valores en cache
REDIS_TTL=600
# El tiemṕo en milisegundos que se espera antes de lanzar un timeout para operaciones con redis
REDIS_TIMEOUT_MS=6000
# El namespace lógico que usará esta aplicación para almacenar valores en redis.  Este valor debe ser único por aplicación.
CACHE_NAMESPACE=axis-framework-edenor-api

# --- OAuth2 / OIDC ---
# Tenant ID de Entra ID
OAUTH2SERVER_TENANT_ID=your-tenant-id
# El host del server OAUTH2
OAUTH2SERVER_AUTHORITY_HOST=https://login.microsoftonline.com
# Timeout en milisegundos
OAUTH2SERVER_TIMEOUT_MS=3000


# --- Servicio de authorization basado en AWS Verified Permissions---
# Region de AWS en que está configurado el policy store de esta aplicación
AWVP_REGION=us-east-1
# Id de policy store de Verified Permissions que define las políticas de acceso de esta aplicación
AWVP_POLICY_STORE_ID=your-policy-store-id
# El namespace usado en el scheme de ese policy store
AWVP_NAMESPACE=axis_core


# --- Axis Logger Edenor---
# El nivel de logging que se desea
AXIS_LOG_LEVEL=debug
# El timezone en que se debe expresar el timestamp de cada log
AXIS_LOG_TZ=America/Argentina/Buenos_Aires
# El nombre del campo que contiene el timestamp del log
AXIS_LOG_TS_NAME=time
# El nombre del campo que se usará como prefijo en cada log
AXIS_LOG_PREFIX_NAME=serviceName
# El valor que se usará como prefijo en cada log
AXIS_LOG_PREFIX_VALUE=axis-framework-edenor-api
# El nombre de la aplicación que se usuará en cada log
AXIS_LOG_APP_NAME=Gubernamentales Backend
# Tipo de integración: ONLINE o BATCH - Para backends de Edenor se usa ONLINE
AXIS_LOG_INTEGRATION_TYPE=ONLINE
# Para backends de Edenor se usa: splunk
AXIS_LOG_TARGET=splunk
# Formato que en que se emiten los logs: text o json
AXIS_LOG_FORMAT=text
# Si el formato es text, se puede poner true para que salgan con colores que faciliten la lectura en consola de los logs
AXIS_LOG_COLORS=true
# Si quiere logear todas las queries de TypeORM.  Si se pone en true, emite logs, si pone false no emite logs y dependen los logs de los logpublishers.
TYPEORM_QUERY_LOGS=false


# --- Configuración de base de datos (general) ---
# Estas variables DB_MASTER_* son OBLIGATORIAS para todos los motores,
# excepto en Oracle cuando usas ORACLE_CONNECT_STRING (ver sección Oracle).
DB_MASTER_HOST=localhost                 # host de la instancia de DB (p.ej., MSSQL/PG/MySQL/MariaDB)
DB_MASTER_PORT=5432                      # puerto de PostgreSQL
DB_MASTER_DATABASE=gubernamentales       # nombre de la base
DB_MASTER_USERNAME=gubernamentales       # usuario local
DB_MASTER_PASSWORD=gubernamentales_dev   # solo para desarrollo local; reemplazar en ambientes reales

# Número de réplicas (0 si no usas replicación)
DB_SLAVE_COUNT=0
DB_REPLICATION_ENABLED=false             # true para habilitar read/write split
# DB_REPLICATION_DEFAULT_MODE=master     # master|slave (por defecto, si no seteas, usa el default del driver)

# Configuración de esclavos (descomenta y ajusta si DB_SLAVE_COUNT > 0)
# Caso general (MySQL/PostgreSQL/MSSQL):
# DB_SLAVE1_HOST=localhost              # host del slave 1
# DB_SLAVE1_PORT=1433                   # puerto del slave 1
# DB_SLAVE1_DATABASE=inversiones        # base de datos del slave 1
# DB_SLAVE1_USERNAME=sa                 # usuario del slave 1
# DB_SLAVE1_PASSWORD=YourStrongPassw0rd # contraseña del slave 1

# DB_SLAVE2_HOST=localhost
# DB_SLAVE2_PORT=1433
# DB_SLAVE2_DATABASE=inversiones
# DB_SLAVE2_USERNAME=sa
# DB_SLAVE2_PASSWORD=YourStrongPassw0rd

# Oracle — dos opciones para slaves:
# A) Con connect string (recomendado por claridad):
# ORACLE_SLAVE1_CONNECT_STRING=//host:1521/ORCLPDB1  # host:port/service del slave 1
# DB_SLAVE1_USERNAME=system                          # usuario del slave 1 (se reusa convención DB_SLAVE*)
# DB_SLAVE1_PASSWORD=MyPass!23
#
# B) Sin connect string:
# DB_SLAVE1_HOST=localhost            # host del slave 1
# DB_SLAVE1_PORT=1521                 # puerto del slave 1
# ORACLE_SLAVE1_SERVICE_NAME=ORCLPDB1 # service name del slave 1 (alternativa a SID)
# # ORACLE_SLAVE1_SID=ORCLCDB         # SID del slave 1 (alternativa a service name)
# DB_SLAVE1_USERNAME=system
# DB_SLAVE1_PASSWORD=MyPass!23
# Nota Oracle: “DB_SLAVE*_DATABASE” no se usa; puedes omitirlo o dejar placeholder si tu pipeline lo exige.


# --- Configuración específica por motor: MSSQL ---
# DB_TYPE=mssql
MSSQL_POOL_MAX=10               # tamaño máximo del pool
MSSQL_POOL_MIN=0                # tamaño mínimo del pool (en dev conviene 0)
MSSQL_POOL_IDLE_MS=30000        # inactividad para cerrar conexiones (ms)
MSSQL_REQUEST_TIMEOUT_MS=15000  # timeout por consulta (ms)
MSSQL_ENCRYPT=false             # TLS; en dev suele ser false (o true si tu instancia lo exige)
MSSQL_TRUST_SERVER_CERT=true    # aceptar cert self‑signed (dev=true, prod=false)
MSSQL_USE_UTC=true              # fechas/horas en UTC
MSSQL_ENABLE_ARITH_ABORT=true   # abortar ante errores aritméticos


# --- Configuración específica por motor: POSTGRESQL ---
DB_TYPE=postgres
POSTGRES_SCHEMA=public                    # esquema por defecto
POSTGRES_SSL=false                        # habilitar SSL
POSTGRES_SSL_REJECT_UNAUTHORIZED=true     # validar certificado si SSL=true
POSTGRES_APP_NAME=gubernamentales-backend # application_name del cliente
POSTGRES_POOL_MAX=10                      # máximo conexiones pool
POSTGRES_POOL_IDLE_MS=30000               # idle antes de cierre (ms)


# --- Configuración específica por motor: MYSQL ---
# DB_TYPE=mysql
# DB_MASTER_PORT=3306                     # puerto MySQL
# MYSQL_CHARSET=utf8mb4                   # charset por defecto
# MYSQL_TIMEZONE=Z                        # zona horaria (Z=UTC)
# MYSQL_MULTIPLE_STATEMENTS=false         # permitir múltiples statements
# MYSQL_DECIMAL_NUMBERS=false             # parsear decimales como number
# MYSQL_POOL_MAX=10                       # máximo conexiones pool
# MYSQL_POOL_MIN=0                        # mínimo conexiones pool


# --- Configuración específica por motor: MARIADB ---
# DB_TYPE=mariadb
# DB_MASTER_PORT=3306                     # puerto MariaDB
# MARIADB_CHARSET=utf8mb4                 # charset por defecto
# MARIADB_TIMEZONE=Z                      # zona horaria (Z=UTC)
# MARIADB_SSL=false                       # SSL para conexiones
# MARIADB_POOL_MAX=10                     # máximo conexiones pool
# MARIADB_POOL_MIN=0                      # mínimo conexiones pool


# --- Configuración específica por motor: ORACLE ---
# Caso A — con connect string (recomendado)
# Nota: si definís ORACLE_CONNECT_STRING, NO son requeridos DB_MASTER_HOST/PORT/DATABASE
#       ni ORACLE_SERVICE_NAME/SID. DB_MASTER_USERNAME/PASSWORD se usan (salvo external auth).
# DB_TYPE=oracle
# ORACLE_CONNECT_STRING=//localhost:1521/XEPDB1  # Easy Connect/TNS
# ORACLE_EXTERNAL_AUTH=false              # autenticación por wallet (true=sin user/pass)
# ORACLE_POOL_MIN=0                       # mínimo conexiones pool
# ORACLE_POOL_MAX=10                      # máximo conexiones pool
# ORACLE_POOL_INCREMENT=1                 # incremento del pool
# ORACLE_POOL_TIMEOUT=60                  # timeout del pool (s)
# ORACLE_STMT_CACHE_SIZE=30               # tamaño del statement cache

# Caso B — sin connect string
# Nota: acá SÍ se usan DB_MASTER_HOST/PORT y se requiere uno de:
#       ORACLE_SERVICE_NAME (PDB/servicio) o ORACLE_SID (instancia).
# DB_TYPE=oracle
# DB_MASTER_HOST=localhost                # host Oracle (requerido en modo manual)
# DB_MASTER_PORT=1521                     # puerto Oracle (requerido en modo manual)
# DB_MASTER_USERNAME=system               # usuario Oracle
# DB_MASTER_PASSWORD=MyPass!23            # contraseña Oracle
# ORACLE_SERVICE_NAME=ORCLPDB1            # service name (alternativa a SID)
# # ORACLE_SID=ORCLCDB                     # SID (alternativa a service name)
# ORACLE_EXTERNAL_AUTH=false              # autenticación por wallet
# ORACLE_POOL_MIN=0                       # mínimo conexiones pool
# ORACLE_POOL_MAX=10                      # máximo conexiones pool
# ORACLE_POOL_INCREMENT=1                 # incremento del pool
# ORACLE_POOL_TIMEOUT=60                  # timeout del pool (s)
# ORACLE_STMT_CACHE_SIZE=30               # tamaño del statement cache
